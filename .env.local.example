# Supabase (new project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Canonical public URL used for outbound links (invites, emails, redirects).
# Falls back to NEXT_PUBLIC_SITE_URL if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# Resend (for transactional email sends — invites, notifications, etc.)
RESEND_API_KEY=your-resend-key
# Optional override for the From header. Defaults to "Attomik <invites@email.attomik.co>"
# when unset. Must be a verified sender on your Resend domain.
RESEND_FROM=Attomik <invites@email.attomik.co>
